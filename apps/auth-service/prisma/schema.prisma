generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Định nghĩa model ví dụ:
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String   @unique
  phoneNumber String
  address     String?
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}
